{
  "name": "default",
  "scope": "CurrentUser",
  "mode": "Quarantine",
  "includeProgramData": true,
  "includeTemp": true,
  "includeCrashDumps": true,
  "minimumFileAgeHours": 24,
  "includePathKeywords": [
    "temp",
    "cache",
    "logs",
    "crashdumps",
    "reportqueue",
    "reportarchive",
    "dumps",
    "tmp"
  ],
  "excludePathPrefixes": []
}
